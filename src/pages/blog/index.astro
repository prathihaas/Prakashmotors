---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = ['All', ...new Set(sortedPosts.map(p => p.data.category))];
---

<Layout title="Tractor Guides & Farming Tips | Prakash Motors Nizamabad" description="Expert tractor buying guides, New Holland reviews, Telangana subsidy news and farming tips from Prakash Motors — authorized New Holland dealer in Nizamabad.">

  <!-- Fixed WhatsApp -->
  <a href="https://wa.me/919030857333?text=Hi%2C%20I%20want%20to%20know%20about%20New%20Holland%20tractors.%20%5BW-PM%5D" target="_blank" class="fixed bottom-6 right-6 z-50 flex items-center gap-3 bg-[#25D366] text-white px-5 py-3 rounded-full shadow-lg hover:bg-green-600 transition-all duration-300 hover:scale-105 group ring-4 ring-white">
    <i data-lucide="message-circle" class="w-6 h-6 fill-current"></i>
    <span class="text-sm font-extrabold">Chat with us</span>
  </a>

  <!-- Navbar -->
  <nav class="fixed w-full z-40 bg-white/95 backdrop-blur-md border-b border-[#001489]/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-20">
        <div class="flex items-center gap-3">
          <div class="w-11 h-11 bg-[#001489] flex items-center justify-center text-white font-black text-2xl shadow-sm"><span class="text-[#FFD100] scale-125">P</span></div>
          <div class="flex flex-col">
            <a href="/" class="text-xl font-black text-[#001489] tracking-tighter uppercase leading-none hover:text-[#000E5C]">Prakash<br>Motors</a>
            <span class="text-[10px] text-gray-500 font-bold tracking-[0.2em] uppercase mt-1 border-t border-gray-200 pt-0.5">NIZAMABAD</span>
          </div>
        </div>
        <div class="flex items-center gap-6">
          <div class="hidden md:flex gap-6 font-bold text-sm text-[#001489] tracking-wide">
            <a href="/#products" class="hover:text-[#000E5C] transition">PRODUCTS</a>
            <a href="/blog" class="text-[#001489] border-b-2 border-[#FFD100]">BLOG</a>
            <a href="/about" class="hover:text-[#000E5C] transition">ABOUT</a>
            <a href="/contact" class="hover:text-[#000E5C] transition">CONTACT</a>
          </div>
          <a href="tel:+919030857333" class="flex items-center gap-2 bg-[#001489] text-white px-5 py-2 rounded-full font-bold hover:bg-[#000E5C] transition shadow-sm">
            <i data-lucide="phone" class="w-4 h-4"></i>
            <span class="text-sm">9030857333</span>
          </a>
        </div>
      </div>
    </div>
  </nav>

  <main class="max-w-7xl mx-auto px-4 py-16 pt-32">

    <!-- Header -->
    <div class="text-center mb-14">
      <span class="inline-block bg-[#001489]/10 text-[#001489] text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full mb-4">Farmer Resources</span>
      <h1 class="text-4xl lg:text-5xl font-black text-[#001489] mb-3">Tractor Guides & Farming Tips</h1>
      <p class="text-lg text-gray-500 max-w-2xl mx-auto">Expert advice, New Holland reviews, Telangana subsidy news and seasonal farming guides — from Nizamabad's trusted tractor dealer.</p>
      <p class="text-[#001489] font-noto mt-2 text-base">ట్రాక్టర్ గైడ్‌లు • వ్యవసాయ చిట్కాలు • తెలంగాణ సబ్సిడీ వార్తలు</p>
    </div>

    <!-- Category Filter -->
    <div class="flex flex-wrap justify-center gap-2 mb-12">
      {categories.map(cat => (
        <span class={`px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wide cursor-pointer transition
          ${cat === 'All'
            ? 'bg-[#001489] text-white'
            : 'bg-gray-100 text-gray-600 hover:bg-[#001489]/10 hover:text-[#001489]'
          }`}>
          {cat}
        </span>
      ))}
    </div>

    <!-- Stats Bar -->
    <div class="flex flex-wrap justify-center gap-8 mb-14 py-6 bg-[#001489]/5 rounded-2xl">
      <div class="text-center">
        <div class="text-3xl font-black text-[#001489]">{allPosts.length}</div>
        <div class="text-xs text-gray-500 font-bold uppercase tracking-wide">Expert Articles</div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-black text-[#001489]">15+</div>
        <div class="text-xs text-gray-500 font-bold uppercase tracking-wide">NH Models Covered</div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-black text-[#001489]">8</div>
        <div class="text-xs text-gray-500 font-bold uppercase tracking-wide">Mandals Served</div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-black text-[#FFD100] stroke-current"><span class="text-[#001489]">20+</span></div>
        <div class="text-xs text-gray-500 font-bold uppercase tracking-wide">Years Experience</div>
      </div>
    </div>

    <!-- Pinned Pillar Post -->
    {sortedPosts.filter(p => p.slug === 'new-holland-vs-mahindra-tractor-telangana-2026' || p.data.category === 'Buying Guide').slice(0,1).map(post => (
      <a href={`/blog/${post.slug}`} class="group block mb-14 bg-white rounded-3xl overflow-hidden shadow-lg hover:shadow-2xl border border-gray-100 transition-all duration-300 lg:grid lg:grid-cols-2">
        <div class="aspect-video lg:aspect-auto overflow-hidden bg-gray-100">
          {post.data.featured_image
            ? <img src={post.data.featured_image} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="eager" />
            : <div class="w-full h-full bg-[#001489]/10 flex items-center justify-center"><span class="text-[#001489] text-6xl font-black">NH</span></div>
          }
        </div>
        <div class="p-10 flex flex-col justify-center">
          <div class="flex items-center gap-2 mb-4">
            <span class="bg-[#FFD100] text-[#001489] text-xs font-black px-3 py-1 rounded-full uppercase tracking-wide">⭐ Featured Guide</span>
            <span class="bg-[#001489]/10 text-[#001489] text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">{post.data.category}</span>
          </div>
          <h2 class="text-2xl lg:text-3xl font-black text-[#001489] mb-2 group-hover:text-[#000E5C] transition leading-tight">{post.data.title}</h2>
          {post.data.title_te && <p class="text-gray-500 font-noto mb-4">{post.data.title_te}</p>}
          <p class="text-gray-600 mb-6 leading-relaxed">{post.data.excerpt}</p>
          <div class="flex items-center gap-4">
            <span class="text-sm text-gray-400">{post.data.date.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
            {post.data.readTime && <span class="text-sm text-gray-400">• {post.data.readTime}</span>}
          </div>
          <span class="mt-6 inline-flex items-center gap-2 text-[#001489] font-bold text-sm group-hover:gap-3 transition-all">
            Read Full Guide <i data-lucide="arrow-right" class="w-4 h-4"></i>
          </span>
        </div>
      </a>
    ))}

    <!-- All Posts Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {sortedPosts.slice(1).map(post => (
        <a href={`/blog/${post.slug}`} class="group bg-white rounded-2xl border border-gray-100 overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col">
          <div class="aspect-video bg-gray-100 overflow-hidden">
            {post.data.featured_image
              ? <img src={post.data.featured_image} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              : <div class="w-full h-full flex items-center justify-center bg-[#001489]/5">
                  <span class="text-[#001489] text-3xl font-black opacity-30">NH</span>
                </div>
            }
          </div>
          <div class="p-6 flex flex-col flex-grow">
            <div class="flex items-center gap-2 mb-3">
              <span class={`text-xs px-2 py-0.5 rounded-full font-bold uppercase tracking-wide
                ${post.data.category === 'Comparison' ? 'bg-orange-50 text-orange-600'
                  : post.data.category === 'Review' ? 'bg-blue-50 text-blue-600'
                  : post.data.category === 'Finance' ? 'bg-green-50 text-green-700'
                  : post.data.category === 'Tips' ? 'bg-yellow-50 text-yellow-700'
                  : post.data.category === 'News' ? 'bg-purple-50 text-purple-700'
                  : 'bg-[#001489]/10 text-[#001489]'
                }`}>{post.data.category}</span>
              {post.data.readTime && <span class="text-xs text-gray-400">{post.data.readTime}</span>}
            </div>
            <h3 class="text-base font-bold text-gray-900 mb-1 group-hover:text-[#001489] transition leading-snug flex-grow">{post.data.title}</h3>
            {post.data.title_te && <p class="text-xs text-gray-400 font-noto mb-2 line-clamp-1">{post.data.title_te}</p>}
            <p class="text-sm text-gray-500 line-clamp-2 mb-4">{post.data.excerpt}</p>
            <div class="flex items-center justify-between mt-auto pt-4 border-t border-gray-50">
              <span class="text-xs text-gray-400 uppercase tracking-wider">
                {post.data.date.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' })}
              </span>
              <span class="text-xs font-bold text-[#001489] group-hover:underline flex items-center gap-1">
                Read <i data-lucide="arrow-right" class="w-3 h-3"></i>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="mt-20 bg-[#001489] rounded-3xl p-10 text-center text-white">
      <h2 class="text-3xl font-black mb-3">Ready to Buy a New Holland Tractor?</h2>
      <p class="text-lg opacity-80 mb-6">Visit Prakash Motors in Nizamabad. We serve all of Nizamabad district — Bodhan, Banswada, Armoor, Balkonda, Bheemgal and beyond.</p>
      <p class="font-noto text-base opacity-70 mb-8">నిజామాబాద్‌లో న్యూ హాలండ్ ట్రాక్టర్ కొనాలంటే ప్రకాశ్ మోటార్స్‌కు రండి</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://wa.me/919030857333?text=Hi%2C%20I%20want%20to%20enquire%20about%20New%20Holland%20tractors.%20%5BW-BLOG%5D" target="_blank"
           class="flex items-center justify-center gap-2 bg-[#25D366] text-white px-8 py-4 rounded-full font-bold text-lg hover:bg-green-600 transition shadow-xl">
          <i data-lucide="message-circle" class="w-5 h-5"></i> WhatsApp Us
        </a>
        <a href="tel:+919030857333" class="flex items-center justify-center gap-2 bg-white text-[#001489] px-8 py-4 rounded-full font-bold text-lg hover:bg-gray-100 transition shadow-xl">
          <i data-lucide="phone" class="w-5 h-5"></i> +91 9030857333
        </a>
      </div>
    </div>

  </main>

  <!-- Footer -->
  <footer class="bg-gray-50 border-t border-gray-200 py-8 mt-16">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <p class="text-sm text-gray-500">© 2026 Prakash Motors, Nizamabad. Authorized New Holland Dealer | Telangana 503001</p>
      <div class="flex justify-center gap-6 mt-3 text-xs text-[#001489] font-bold">
        <a href="/">Home</a>
        <a href="/#products">Products</a>
        <a href="/blog">Blog</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </div>
    </div>
  </footer>

  <script>if (typeof lucide !== 'undefined') { lucide.createIcons(); }</script>
</Layout>

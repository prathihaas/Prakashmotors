---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const {
  title, title_te, seo_title, seo_description,
  featured_image, excerpt, category, readTime, author, tags,
  date,
} = post.data;

const displayDate = date.toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' });

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": seo_title || title,
  "description": seo_description || excerpt,
  "image": featured_image || "https://www.prakashmotors.in/og-image.jpg",
  "author": { "@type": "Person", "name": author || "Prakash Motors Team" },
  "publisher": {
    "@type": "Organization",
    "name": "Prakash Motors",
    "logo": { "@type": "ImageObject", "url": "https://www.prakashmotors.in/logo.png" }
  },
  "datePublished": date.toISOString(),
  "dateModified": date.toISOString(),
  "url": Astro.url.href,
  "mainEntityOfPage": { "@type": "WebPage", "@id": Astro.url.href }
};
---

<Layout title={seo_title} description={seo_description} image={featured_image} ogType="article">
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <!-- Navbar -->
  <nav class="fixed w-full z-40 bg-white/95 backdrop-blur-md border-b border-[#001489]/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-20">
        <a href="/" class="flex items-center gap-3">
          <div class="w-10 h-10 bg-[#001489] flex items-center justify-center text-white font-black text-xl shadow-sm">
            <span class="text-[#FFD100] scale-125">P</span>
          </div>
          <span class="text-lg font-black text-[#001489] tracking-tighter uppercase leading-none">Prakash<br>Motors</span>
        </a>
        <div class="flex items-center gap-4">
          <a href="/blog" class="text-sm font-bold text-gray-500 hover:text-[#001489]">All Posts</a>
          <a href="/" class="text-sm font-bold text-[#001489] hover:text-[#000E5C] flex items-center gap-1">
            <i data-lucide="arrow-left" class="w-4 h-4"></i> Home
          </a>
        </div>
      </div>
    </div>
  </nav>

  <article class="pt-28 pb-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Header -->
      <header class="mb-10 text-center">
        <div class="flex items-center justify-center gap-3 mb-5">
          <span class="inline-block bg-[#001489]/8 text-[#001489] font-bold tracking-widest uppercase text-xs px-3 py-1 rounded-full">
            {category}
          </span>
          {readTime && <span class="text-xs text-gray-400 font-semibold">{readTime}</span>}
        </div>
        <h1 class="text-3xl md:text-5xl font-black text-[#001489] mb-4 leading-tight">{title}</h1>
        {title_te && <h2 class="font-telugu text-xl font-bold text-gray-400 mb-4">{title_te}</h2>}
        <p class="text-lg text-gray-500 max-w-2xl mx-auto leading-relaxed">{excerpt}</p>
        <div class="flex justify-center gap-6 mt-6 text-sm text-gray-400 font-semibold uppercase tracking-wider">
          <span>{displayDate}</span>
          {author && <span>By {author}</span>}
        </div>
      </header>

      <!-- Hero image -->
      {featured_image && (
        <img
          src={featured_image}
          alt={title}
          class="w-full h-[400px] object-cover rounded-2xl shadow-xl mb-12"
          loading="eager"
        />
      )}

      <!-- Tags -->
      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-10">
          {tags.map(tag => (
            <span class="text-xs bg-[#001489]/5 text-[#001489] px-3 py-1 rounded-full font-semibold">{tag}</span>
          ))}
        </div>
      )}

      <!-- Article body -->
      <div class="prose prose-lg prose-blue max-w-none text-gray-600
        prose-headings:font-black prose-headings:text-[#001489]
        prose-a:text-[#001489] prose-a:font-bold
        prose-img:rounded-xl prose-img:shadow-md
        prose-strong:text-[#001489]
        prose-table:border prose-th:bg-[#001489] prose-th:text-white prose-th:p-3 prose-td:p-3 prose-td:border">
        <Content />
      </div>

      <!-- CTA -->
      <div class="mt-16 pt-10 border-t border-gray-100 text-center bg-[#001489]/3 rounded-2xl p-8">
        <h3 class="font-black text-[#001489] text-2xl mb-2">Want to know more?</h3>
        <p class="text-gray-500 mb-6">Talk to our experts at Prakash Motors, Nizamabad</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="https://wa.me/919030857333?text=Hi%2C%20I%20read%20your%20blog%20and%20want%20to%20know%20more%20about%20tractors.%20%5BW-PM%5D" target="_blank"
             class="inline-flex items-center gap-2 bg-[#25D366] text-white px-6 py-3 rounded-full font-bold shadow-lg hover:bg-green-600 transition-all">
            <i data-lucide="message-circle" class="w-5 h-5"></i>
            Chat on WhatsApp
          </a>
          <a href="tel:+919030857333"
             class="inline-flex items-center gap-2 bg-[#001489] text-white px-6 py-3 rounded-full font-bold shadow-lg hover:bg-[#000E5C] transition-all">
            <i data-lucide="phone" class="w-5 h-5"></i>
            Call Now
          </a>
        </div>
      </div>

    </div>
  </article>

  <script>if (typeof lucide !== 'undefined') { lucide.createIcons(); }</script>
</Layout>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>New Holland Tractors in Nizamabad — Prakash Motors (Authorized Dealer)</title>
  <meta name="description" content="Authorized New Holland tractor dealer in Nizamabad. 3230 NX, 3630 TX, Excel 4510/4710, Workmaster 105. EMI from ₹12,000/month. Free farm demo. 20+ years · 2,000+ tractors delivered." />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/jpeg" href="/favicon.jpg" />
  <meta name="theme-color" content="#001489" />

  <!-- GTM -->
  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','GTM-MCMZWFT3');</script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Noto+Sans+Telugu:wght@400;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }
    body { font-family: 'Inter', system-ui, sans-serif; color: #0B1437; background: #fff; -webkit-tap-highlight-color: rgba(0,20,137,.12); line-height: 1.55; }
    .fn { font-family: 'Noto Sans Telugu', sans-serif; }
    a { color: inherit; text-decoration: none; }
    img { display: block; max-width: 100%; height: auto; }
    a, button, summary { touch-action: manipulation; }
    a .deco, a .deco * { pointer-events: none; }
    .tap { min-height: 48px; display: inline-flex; align-items: center; justify-content: center; }
    .wrap { max-width: 1120px; margin: 0 auto; padding: 0 20px; }
    .pill { display:inline-flex; align-items:center; gap:6px; padding:6px 12px; border-radius:999px; font-size:12px; font-weight:700; letter-spacing:.02em; }
    .btn-primary { background:#001489; color:#fff; border-radius:12px; font-weight:800; padding:0 22px; gap:8px; box-shadow: 0 6px 20px -8px rgba(0,20,137,.5); }
    .btn-primary:hover { background:#000E5C; }
    .btn-wa { background:#25D366; color:#fff; border-radius:12px; font-weight:800; padding:0 22px; gap:8px; box-shadow: 0 6px 20px -8px rgba(37,211,102,.55); }
    .btn-wa:hover { background:#1eb558; }
    .btn-ghost { background:#fff; color:#001489; border:2px solid #E5E7EB; border-radius:12px; font-weight:700; padding:0 22px; gap:8px; }
    .card { background:#fff; border:1px solid #E6E8F0; border-radius:18px; }
    .section { padding: 56px 0; }
    .h-eyebrow { color:#001489; font-weight:800; font-size:12px; letter-spacing:.12em; text-transform:uppercase; }
    .h2 { font-size: clamp(24px,3.4vw,34px); font-weight:900; line-height:1.15; color:#0B1437; letter-spacing:-.01em; }
    .sub { color:#475069; font-size:15px; }
    details > summary { list-style:none; cursor:pointer; }
    details > summary::-webkit-details-marker { display:none; }
    details[open] .chev { transform: rotate(180deg); }
    .chev { transition: transform .2s ease; }
    @media (max-width: 640px) {
      .section { padding: 40px 0; }
      .wrap { padding: 0 16px; }
    }
  </style>
</head>
<body>
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MCMZWFT3" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

<!-- Top trust strip -->

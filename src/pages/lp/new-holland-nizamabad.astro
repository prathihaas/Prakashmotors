    features: ["FPT S8000 engine", "12+3 creeper gears", "Double clutch", "ROPS safety"],
    wa: "I want the on-road price of New Holland 3630 TX Super Plus. [W-LP-3630]" },
  { model: "New Holland 3230 NX", hp: "42 HP", priceFrom: "₹6.9L", badge: "Best for 3–5 acres",
    img: "https://cnhi-p-001-delivery.sitecorecontenthub.cloud/api/public/content/5390d7391c714509b5311e7f33cc1b3c?v=407996ce&t=Size1000",
    features: ["42 HP engine", "8+2 gears", "Power steering", "Fuel-efficient"],

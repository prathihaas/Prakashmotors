<style>
  @media (min-width: 900px) {
    #hero-grid { grid-template-columns: 1.1fr 1fr !important; gap: 48px !important; }
  }
</style>

<!-- Brand partners / trust row -->
<section style="background:#F6F7FB; border-bottom:1px solid #EAECF4; padding:22px 0;">
  <div class="wrap" style="display:flex; justify-content:space-around; align-items:center; gap:14px; flex-wrap:wrap;">
    {[
      { t: "CNH Industrial Authorized", s: "Manufacturer-certified" },
      { t: "SBI · Andhra · NABARD", s: "On-site finance desk" },
      { t: "100% Genuine OEM parts", s: "Factory-packed" },
      { t: "24-hr breakdown response", s: "Across 6 mandals" },
    ].map(x => (
      <div style="text-align:center; flex:1; min-width:140px;">
        <div style="font-size:13px; font-weight:800; color:#0B1437;">{x.t}</div>
        <div style="font-size:11px; color:#6B7280; margin-top:2px;">{x.s}</div>
      </div>
    ))}
  </div>
</section>

<!-- MODELS -->
<section class="section">
  <div class="wrap">
    <div style="text-align:center; margin-bottom:36px;">
      <div class="h-eyebrow">Our lineup</div>
      <h2 class="h2" style="margin-top:8px;">Choose your New Holland</h2>
      <p class="sub" style="margin-top:8px;">Every model in stock at Nizamabad. Tap any card to get today's on-road price on WhatsApp.</p>
    </div>

    <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap:18px;">
      {tractors.map(t => (
        <a href={waLink(t.wa)} target="_blank" rel="noopener noreferrer"
           class="card"
           style="display:flex; flex-direction:column; overflow:hidden; transition: transform .2s ease, box-shadow .2s ease; min-height:420px;">
          <div style="position:relative; aspect-ratio: 4/3; background: linear-gradient(135deg, #F3F5FC 0%, #E8ECF8 100%); overflow:hidden;">
            <img src={t.img} alt={t.model} loading="lazy" style="width:100%; height:100%; object-fit:cover;" />
            <div class="deco" style="position:absolute; top:12px; left:12px; background:#001489; color:#fff; font-size:10px; font-weight:800; text-transform:uppercase; letter-spacing:.08em; padding:6px 10px; border-radius:6px;">
              {t.badge}
            </div>
            <div class="deco" style="position:absolute; top:12px; right:12px; background:#FFD100; color:#0B1437; font-size:11px; font-weight:900; padding:6px 10px; border-radius:6px;">
              {t.hp}
            </div>
          </div>
          <div style="padding:20px; display:flex; flex-direction:column; flex:1;">
            <h3 style="font-weight:800; font-size:17px; color:#0B1437; line-height:1.25; margin-bottom:4px;">{t.model}</h3>
            <div style="display:flex; align-items:baseline; gap:6px; margin-bottom:12px;">
              <span style="font-size:11px; color:#6B7280; font-weight:600;">from</span>
              <span style="font-size:20px; font-weight:900; color:#001489;">{t.priceFrom}</span>
              <span style="font-size:11px; color:#6B7280;">ex-showroom</span>
            </div>
            <ul style="list-style:none; margin:0; padding:0; flex:1;">
              {t.features.map(f => (
                <li style="font-size:13px; color:#475069; padding:3px 0; display:flex; align-items:start; gap:8px;">

    wa: "I want the on-road price of New Holland Excel 4510. [W-LP-4510]" },
  { model: "New Holland Excel 4710", hp: "47 HP", priceFrom: "₹8.2L", badge: "Turmeric · Soybean",
    img: "https://cnhi-p-001-delivery.sitecorecontenthub.cloud/api/public/content/9fe2f82fec694104bc2b0602ed8583e9?v=f140b8a9&t=size500",
    features: ["47 HP engine", "16+4 gears", "Full hydraulics", "Rotavator-ready"],
    wa: "I want the on-road price of New Holland Excel 4710. [W-LP-4710]" },
  { model: "New Holland Workmaster 105", hp: "105 HP", priceFrom: "₹18.5L", badge: "Premium",
    img: "https://cnhi-p-001-delivery.sitecorecontenthub.cloud/api/public/content/5390d7391c714509b5311e7f33cc1b3c?v=407996ce&t=Size1000",
    features: ["105 HP powerhouse", "Synchro shuttle", "AC cabin option", "Commercial-grade"],
    wa: "I want the on-road price of New Holland Workmaster 105. [W-LP-WM105]" },
  { model: "New Holland TC5.30 Combine", hp: "Harvester", priceFrom: "On request", badge: "High income",
    img: "https://cnhi-p-001-delivery.sitecorecontenthub.cloud/api/public/content/9fe2f82fec694104bc2b0602ed8583e9?v=f140b8a9&t=size500",
    features: ["Paddy & wheat", "Custom hiring ~₹8,000/day", "Quick ROI", "Easy finance"],
    wa: "I want the on-road price of New Holland TC5.30 Combine Harvester. [W-LP-TC530]" },
];

const branches = [
  { name: "Nizamabad (Main)", address: "Opposite New Bus Stand" },
  { name: "Armoor", address: "Main Road" },
  { name: "Bodhan", address: "Market Road" },
  { name: "Banswada", address: "Near Bus Stand" },
  { name: "Kamareddy", address: "Main Road" },
  { name: "Yellareddy", address: "Near Mandal Office" },
];

const faqs = [
  { q: "What is the price of New Holland 3630 in Nizamabad?", a: "The 3630 TX Super Plus is priced around ₹8.5–10 lakh ex-showroom (April 2026). Final on-road price depends on attachments, extended warranty and district RTO. Call or WhatsApp us for today's exact quote." },
  { q: "Does Prakash Motors offer tractor loan?", a: "Yes. We arrange loans through SBI, Andhra Bank, NABARD and private lenders — up to 95% of the tractor cost, EMI from ₹12,000/month, tenure up to 7 years. Typical approval in 48 hours with Aadhaar + land records." },
  { q: "Can I get a farm demo before buying?", a: "Yes. Book a free farm demo — our team brings the tractor to your field so you can try it on your actual soil before deciding." },
  { q: "Which tractor suits 5 acres in Nizamabad?", a: "For 3–8 acre farms, the 3230 NX (42 HP) or 3630 TX (50 HP) are the most popular choices. For cotton and paddy, the Excel 4510 is a strong pick. Share your crop details with us and we'll recommend the right model." },
  { q: "Do you service tractors bought elsewhere?", a: "Yes. Our Nizamabad workshop services all New Holland tractors regardless of where they were purchased. Genuine OEM parts, 24-hour breakdown response." },
];

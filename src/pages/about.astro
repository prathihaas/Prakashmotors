---
import Layout from "../layouts/Layout.astro";

const title = "About Prakash Motors | Authorized New Holland Dealer Nizamabad Since 2005";
const description = "Prakash Motors is Nizamabad's authorized New Holland agriculture equipment dealer. Serving farmers across Nizamabad, Kamareddy, Jagtial and Karimnagar districts with tractors, harvesters and genuine service.";
---

<Layout title={title} description={description}>

  <!-- Navbar -->
  <nav class="fixed w-full z-40 bg-white/95 backdrop-blur-md border-b border-[#001489]/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-20">
        <a href="/" class="flex items-center gap-3">
          <div class="w-10 h-10 bg-[#001489] flex items-center justify-center text-white font-black text-xl shadow-sm"><span class="text-[#FFD100] scale-125">P</span></div>
          <span class="text-lg font-black text-[#001489] tracking-tighter uppercase leading-none">Prakash<br>Motors</span>
        </a>
        <a href="/" class="text-sm font-bold text-[#001489] hover:text-[#000E5C] flex items-center gap-1">
          <i data-lucide="arrow-left" class="w-4 h-4"></i> Back to Home
        </a>
      </div>
    </div>
  </nav>
  <main class="pt-28 pb-24 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-14">
        <h1 class="text-4xl md:text-5xl font-black text-[#001489] uppercase mb-3 leading-tight">About Prakash Motors</h1>
        <p class="font-telugu text-2xl font-bold text-gray-500 mb-4">ప్రకాష్ మోటార్స్ గురించి</p>
        <p class="text-lg text-gray-600 max-w-3xl">Authorized New Holland agriculture equipment dealer in Nizamabad, Telangana — trusted by farmers across 4 districts for over two decades.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-16 items-center">
        <div>
          <h2 class="text-2xl font-black text-[#001489] uppercase mb-4">Our Story</h2>
          <div class="space-y-4 text-gray-700 leading-relaxed">
            <p>Prakash Motors was established with a single mission: to bring world-class New Holland agricultural equipment to the farmers of Nizamabad and surrounding districts.</p>
            <p>Starting from a small showroom opposite the New Bus Stand in Nizamabad, we have grown into the most trusted New Holland dealer in the region — serving thousands of farmers, contractors, and agricultural entrepreneurs.</p>
            <p>Today, we stock the full range of New Holland tractors (17 HP to 106 HP), combine harvesters, and specialized farm equipment — backed by factory-trained technicians and genuine New Holland spare parts.</p>
          </div>
          <p class="font-telugu text-gray-500 mt-4">మేము నిజామాబాద్ జిల్లా రైతులకు అధికారిక న్యూ హాలండ్ యంత్రాలను అందిస్తున్నాము.</p>
        </div>
        <div class="bg-[#001489] rounded-2xl p-10 text-white text-center">
          <div class="grid grid-cols-2 gap-8">
            <div><p class="text-4xl font-black text-[#FFD100]">20+</p><p class="text-sm font-bold uppercase tracking-wide mt-1 text-white/80">Years in Business</p><p class="font-telugu text-white/60 text-xs mt-1">సంవత్సరాల అనుభవం</p></div>
            <div><p class="text-4xl font-black text-[#FFD100]">2000+</p><p class="text-sm font-bold uppercase tracking-wide mt-1 text-white/80">Farmers Served</p><p class="font-telugu text-white/60 text-xs mt-1">రైతులకు సేవ</p></div>
            <div><p class="text-4xl font-black text-[#FFD100]">16+</p><p class="text-sm font-bold uppercase tracking-wide mt-1 text-white/80">Machine Models</p><p class="font-telugu text-white/60 text-xs mt-1">యంత్రాల మోడళ్లు</p></div>
            <div><p class="text-4xl font-black text-[#FFD100]">4</p><p class="text-sm font-bold uppercase tracking-wide mt-1 text-white/80">Districts Covered</p><p class="font-telugu text-white/60 text-xs mt-1">జిల్లాలలో సేవలు</p></div>
          </div>
        </div>
      </div>
      <div class="bg-gray-50 rounded-2xl p-8 mb-12 border border-gray-100">
        <h2 class="text-xl font-black text-[#001489] uppercase mb-6">New Holland Authorisation &amp; Certifications</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          <div class="text-center"><div class="w-14 h-14 bg-[#001489] rounded-xl flex items-center justify-center mx-auto mb-3"><i data-lucide="award" class="w-7 h-7 text-[#FFD100]"></i></div><p class="font-bold text-gray-800">Authorized Dealer</p><p class="text-gray-500 text-sm mt-1">Official New Holland Agriculture dealership — authorized to sell and service all NH models</p></div>
          <div class="text-center"><div class="w-14 h-14 bg-[#001489] rounded-xl flex items-center justify-center mx-auto mb-3"><i data-lucide="wrench" class="w-7 h-7 text-[#FFD100]"></i></div><p class="font-bold text-gray-800">Factory-Trained Technicians</p><p class="text-gray-500 text-sm mt-1">Service team trained and certified by New Holland Agriculture India</p></div>
          <div class="text-center"><div class="w-14 h-14 bg-[#001489] rounded-xl flex items-center justify-center mx-auto mb-3"><i data-lucide="package" class="w-7 h-7 text-[#FFD100]"></i></div><p class="font-bold text-gray-800">Genuine Spare Parts</p><p class="text-gray-500 text-sm mt-1">Stocked with original NH spare parts — fast delivery to minimise downtime during harvest season</p></div>
        </div>
      </div>
      <div class="mb-12">
        <h2 class="text-xl font-black text-[#001489] uppercase mb-4">Districts We Serve</h2>
        <p class="text-gray-600 mb-6">Prakash Motors provides sales, service, and spare parts support across the following districts in Telangana:</p>
        <div class="flex flex-wrap gap-3">
          {['Nizamabad','Kamareddy','Jagtial','Karimnagar','Rajanna Sircilla','Peddapalli','Mancherial','Nirmal'].map(district => (
            <span class="bg-[#001489]/5 border border-[#001489]/20 text-[#001489] font-bold px-4 py-2 rounded-lg text-sm">{district}</span>
          ))}
        </div>
      </div>
      <div class="bg-[#001489] rounded-2xl p-10 text-center text-white">
        <h2 class="text-2xl font-black uppercase mb-2">Visit Our Showroom</h2>
        <p class="font-telugu text-lg font-bold text-white/70 mb-2">మా షోరూమ్‌ను సందర్శించండి</p>
        <p class="text-white/80 mb-2">Opposite New Bus Stand, Nizamabad, Telangana 503001</p>
        <p class="text-white/60 mb-8">Mon–Sat 9 AM–7 PM | <a href="tel:+919030857333" class="underline">+91 90308 57333</a></p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/#products" class="bg-[#FFD100] text-[#001489] font-black px-8 py-3 rounded-xl hover:bg-yellow-300 transition uppercase tracking-wide">View All Machinery</a>
          <a href="/contact" class="bg-white/10 text-white font-bold px-8 py-3 rounded-xl hover:bg-white/20 transition border border-white/30">Contact Us</a>
        </div>
      </div>
    </div>
  </main>
  <script>if (typeof lucide !== 'undefined') { lucide.createIcons(); }</script>
</Layout>

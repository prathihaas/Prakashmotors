---
// SEOHead.astro - Prakash Motors (New Holland)
const {
  title = "Prakash Motors | Authorized New Holland Dealer in Nizamabad, Telangana",
  description = "Prakash Motors is an authorized New Holland dealer in Nizamabad, Telangana 503001. Buy tractors, farm equipment, and get expert service and genuine parts.",
  canonical = Astro.url.href,
  image = "/og-image.jpg",
} = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Prakash Motors",
  "url": "https://www.prakashmotors.in",
  "logo": "https://www.prakashmotors.in/logo.png",
  "image": "https://www.prakashmotors.in/og-image.jpg",
  "description": "Authorized New Holland dealer in Nizamabad, Telangana. Tractors, farm equipment, genuine parts, and expert agricultural service.",
  "telephone": "+91-9030857333",
  "brand": { "@type": "Brand", "name": "New Holland" },
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Opposite New Bus Stand",
    "addressLocality": "Nizamabad",
    "addressRegion": "Telangana",
    "postalCode": "503001",
    "addressCountry": "IN"
  },
  "geo": { "@type": "GeoCoordinates", "latitude": 18.6725, "longitude": 78.0941 },
  "openingHoursSpecification": [{
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
    "opens": "09:00",
    "closes": "19:00"
  }],
  "sameAs": [
    "https://www.facebook.com/prakashmotors",
    "https://www.instagram.com/prakashmotors"
  ]
};
---
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={new URL(image, Astro.site).toString()} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content="image/jpeg" />
<meta property="og:site_name" content="Prakash Motors" />
<meta property="og:locale" content="en_IN" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(image, Astro.site).toString()} />

<!-- Geo Tags -->
<meta name="geo.region" content="IN-TG" />
<meta name="geo.placename" content="Nizamabad, Telangana" />
<meta name="geo.position" content="18.6725;78.0941" />
<meta name="ICBM" content="18.6725, 78.0941" />

<!-- Hreflang — signals English content with x-default fallback -->
<link rel="alternate" hreflang="en" href={canonical} />
<link rel="alternate" hreflang="x-default" href={canonical} />

<!-- JSON-LD Structured Data — set:html renders parsed JSON, not literal expression -->
<script type="application/ld+json" set:html={JSON.stringify(schema)} />

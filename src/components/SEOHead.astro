---
// SEOHead.astro - Prakash Motors (New Holland)
interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  ogType?: string;
  noOrgSchema?: boolean;
}

const {
  title = "Prakash Motors | Authorized New Holland Dealer in Nizamabad, Telangana",
  description = "Prakash Motors is an authorized New Holland dealer in Nizamabad, Telangana 503001. Buy tractors, farm equipment, and get expert service and genuine parts.",
  canonical = Astro.url.href,
  image = "/og-image.jpg",
  ogType = "website",
  noOrgSchema = false,
} = Astro.props;

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Store",
  "@id": "https://www.prakashmotors.in/#organization",
  "additionalType": "https://schema.org/AutoDealer",
  "name": "Prakash Motors",
  "url": "https://www.prakashmotors.in",
  "logo": {
    "@type": "ImageObject",
    "url": "https://www.prakashmotors.in/favicon.jpg",
    "width": 200,
    "height": 200
  },
  "image": "https://www.prakashmotors.in/og-image.jpg",
  "description": "Authorized New Holland Agriculture dealer in Nizamabad, Telangana. Tractors, combine harvesters, genuine parts, and expert agricultural service since 2003.",
  "telephone": "+91-9030857333",
  "foundingDate": "2003",
  "brand": { "@type": "Brand", "name": "New Holland Agriculture" },
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Opposite New Bus Stand",
    "addressLocality": "Nizamabad",
    "addressRegion": "Telangana",
    "postalCode": "503001",
    "addressCountry": "IN"
  },
  "geo": { "@type": "GeoCoordinates", "latitude": 18.6725, "longitude": 78.0941 },
  "openingHoursSpecification": [{
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
    "opens": "09:00",
    "closes": "19:00"
  }],
  "priceRange": "₹₹₹",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.7",
    "reviewCount": "148",
    "bestRating": "5",
    "worstRating": "1"
  },
  "review": [
    {
      "@type": "Review",
      "author": { "@type": "Person", "name": "Rajaiah Goud" },
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
      "reviewBody": "Bought 3630 TX last year. Runs my 8 acres of cotton without fuss. Prakash Motors arranged the EMI within 2 days — paperwork was handled cleanly.",
      "datePublished": "2025-10-15"
    },
    {
      "@type": "Review",
      "author": { "@type": "Person", "name": "Venkat Reddy" },
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
      "reviewBody": "Excel 4510 for paddy. Three seasons in, zero service issues. The free camp in our village saved me a trip to town.",
      "datePublished": "2025-11-02"
    },
    {
      "@type": "Review",
      "author": { "@type": "Person", "name": "Narsimha Rao" },
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
      "reviewBody": "Compared quotes from three dealers — Prakash gave the clearest breakdown and didn't push extras I didn't need. Service team is local and reachable.",
      "datePublished": "2025-12-08"
    },
    {
      "@type": "Review",
      "author": { "@type": "Person", "name": "Suresh Yadav" },
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
      "reviewBody": "New Holland 3230 for my 5-acre turmeric farm. Fuel efficiency is excellent. On-farm demo before purchase convinced me completely.",
      "datePublished": "2026-01-20"
    }
  ],
  "areaServed": [
    "Nizamabad", "Kamareddy", "Armoor", "Bodhan", "Banswada", "Yellareddy",
    "Balkonda", "Bheemgal", "Nirmal", "Karimnagar", "Jagtial", "Telangana"
  ],
  "sameAs": [
    "https://www.facebook.com/prakashmotors",
    "https://www.instagram.com/prakashmotors"
  ]
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://www.prakashmotors.in/#website",
  "url": "https://www.prakashmotors.in",
  "name": "Prakash Motors",
  "publisher": { "@id": "https://www.prakashmotors.in/#organization" }
};

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": canonical,
  "url": canonical,
  "name": title,
  "description": description,
  "isPartOf": { "@id": "https://www.prakashmotors.in/#website" },
  "about": { "@id": "https://www.prakashmotors.in/#organization" }
};
---
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />

<!-- Resource hints for performance -->
<link rel="preconnect" href="https://www.googletagmanager.com" />
<link rel="dns-prefetch" href="https://www.googletagmanager.com" />
<link rel="preconnect" href="https://www.google-analytics.com" />
<link rel="dns-prefetch" href="https://www.google-analytics.com" />

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={new URL(image, Astro.site).toString()} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content="image/jpeg" />
<meta property="og:site_name" content="Prakash Motors" />
<meta property="og:locale" content="en_IN" />
<meta property="og:locale:alternate" content="te_IN" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(image, Astro.site).toString()} />

<!-- Geo Tags -->
<meta name="geo.region" content="IN-TG" />
<meta name="geo.placename" content="Nizamabad, Telangana" />
<meta name="geo.position" content="18.6725;78.0941" />
<meta name="ICBM" content="18.6725, 78.0941" />

<!-- Hreflang -->
<link rel="alternate" hreflang="en" href={canonical} />
<link rel="alternate" hreflang="x-default" href={canonical} />

<!-- WebSite + WebPage schema — always present -->
<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />

<!-- Org schema — suppressed on pages that define their own richer schema -->
{!noOrgSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
)}

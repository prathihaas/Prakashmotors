---
import SEOHead from '../components/SEOHead.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  ogType?: string;
  noOrgSchema?: boolean;
}

const {
  title,
  description = "Prakash Motors — Nizamabad's #1 New Holland dealer. Best price on 3630 TX, 3600-2 Tractors, Sugarcane & Silver Track Harvesters. EMI available. Free demo. ☎ +91 9030857333.",
  canonical,
  image = "/og-image.jpg",
  ogType,
  noOrgSchema = false,
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/jpeg" href="/favicon.jpg" />
    <link rel="apple-touch-icon" href="/favicon.jpg" />
    <meta name="theme-color" content="#001489" />
    <SEOHead title={title} description={description} canonical={canonical} image={image} ogType={ogType} noOrgSchema={noOrgSchema} />
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-MCMZWFT3');</script>
    <!-- End Google Tag Manager -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Telugu:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script src="https://unpkg.com/lucide@0.469.0/dist/umd/lucide.min.js"></script>
    <style>
      .font-telugu { font-family: 'Noto Sans Telugu', sans-serif; }
      @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-6px); } }
      .animate-float { animation: float 3s ease-in-out infinite; }

      /* Decorative elements: hint the cursor that they aren't tappable */
      .no-tap, .no-tap * { pointer-events: none; user-select: none; }

      /* Blog: stop <strong> from looking like a link (was causing dead clicks) */
      article.prose strong, .prose strong { color: #0B1437; font-weight: 800; }
      article.prose strong:not(a strong), .prose strong:not(a strong) {
        cursor: text; background: linear-gradient(transparent 60%, rgba(255,209,0,.35) 60%);
        padding: 0 2px; border-radius: 2px;
      }

      /* Toast for desktop tel: fallback */
      #tel-toast {
        position: fixed; left: 50%; bottom: 96px;
        transform: translateX(-50%) translateY(20px);
        background: #0B1437; color: #FFD100;
        padding: 12px 18px; border-radius: 12px;
        font-size: 14px; font-weight: 700;
        opacity: 0; transition: opacity .2s ease, transform .2s ease;
        z-index: 9999; pointer-events: none;
        box-shadow: 0 12px 30px -8px rgba(0,0,0,.4);
      }
      #tel-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
    </style>
  </head>
  <body class="bg-white text-gray-900 min-h-screen flex flex-col">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MCMZWFT3"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <slot />

    <!-- Global desktop tel: fallback (copies number on desktop browsers without dialler) -->
    <div id="tel-toast" role="status" aria-live="polite"></div>
    <script>
      (function () {
        var toast = document.getElementById('tel-toast');
        var t;
        function show(msg) {
          if (!toast) return;
          toast.textContent = msg;
          toast.classList.add('show');
          clearTimeout(t);
          t = setTimeout(function () { toast.classList.remove('show'); }, 3000);
        }
        var isMobile = /Mobi|Android|iPhone|iPad|iPod|Windows Phone/i.test(navigator.userAgent);
        document.addEventListener('click', function (e) {
          var a = e.target && e.target.closest && e.target.closest('a[href^="tel:"]');
          if (!a) return;
          if (isMobile) return;
          e.preventDefault();
          var num = a.getAttribute('href').replace('tel:', '').replace(/\s+/g, '');
          try {
            if (navigator.clipboard && navigator.clipboard.writeText) {
              navigator.clipboard.writeText(num);
              show('📞 Number copied: ' + num);
            } else {
              show('📞 Call us: ' + num);
            }
          } catch (err) {
            show('📞 Call us: ' + num);
          }
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event: 'tel_click_desktop', phone: num });
        }, false);
      })();
    </script>
  </body>
</html>
